          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Step 3: Train model on balanced data\n",
        "model_smote = LogisticRegression(max_iter=1000)\n",
        "model_smote.fit(X_train_balanced, y_train_balanced)\n",
        "\n",
        "# Step 4: Evaluate on ORIGINAL test set\n",
        "predictions_smote = model_smote.predict(X_test)\n",
        "accuracy_smote =accuracy_score(y_test, predictions_smote)\n",
        "\n",
        "print(\"Model Accuracy after SMOTE:.\", round(accuracy_smote * 100, 2), \"%\")\n",
        "print(\"\\nDetailed Report:\")\n",
        "print(classification_report(y_test, predictions_smote))"
